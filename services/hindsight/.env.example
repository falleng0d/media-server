# Hindsight service environment
# Copy into Dokploy/environment settings or a local .env before running this compose file.

DOMAIN=example.com
TZ=UTC

# Image/version
HINDSIGHT_VERSION=latest

# PostgreSQL with pgvector
HINDSIGHT_DB_USER=hindsight_user
HINDSIGHT_DB_NAME=hindsight_db
HINDSIGHT_DB_PASSWORD=SET_IN_DOKPLOY

# Hindsight LLM provider
HINDSIGHT_API_LLM_PROVIDER=openai
HINDSIGHT_API_LLM_MODEL=gpt-4o-mini
HINDSIGHT_API_LLM_API_KEY=SET_IN_DOKPLOY

# API auth and Control Plane auth. Use two different long random values.
HINDSIGHT_API_TENANT_API_KEY=SET_IN_DOKPLOY
HINDSIGHT_CP_ACCESS_KEY=SET_IN_DOKPLOY

# Stable worker ID for this NAS deployment
HINDSIGHT_API_WORKER_ID=dark-nas-hindsight
